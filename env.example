# 複製為 .env 後填入真值。本機執行：
#   flutter run --dart-define-from-file=.env
# Release：
#   flutter build ipa --dart-define-from-file=.env

GEMINI_API_KEY=
MATHPIX_APP_ID=
MATHPIX_APP_KEY=
REVENUECAT_IOS_API_KEY=
REVENUECAT_ANDROID_API_KEY=
REVENUECAT_ENTITLEMENT_ID=premium

MATH_OCR_PROVIDER=auto

GEMINI_SOLVE_MODEL_MATH=gemini-2.0-flash
GEMINI_SOLVE_MODEL_MATH_WITH_IMAGE=gemini-2.0-flash
# Optional: geometry solving with image can use a stronger model
GEMINI_SOLVE_MODEL_GEOMETRY_WITH_IMAGE=gemini-2.5-pro

# GEMINI_SOLVE_ALWAYS_ATTACH_IMAGE=1
# GEMINI_SOLVE_ALWAYS_ATTACH_IMAGE_FOR_MATH=1
# GEMINI_SOLVE_OMIT_IMAGE_WHEN_TEXT_COMPLETE=1
# GEMINI_SOLVE_VALIDATE_MATH_WITH_IMAGE=0
# GEMINI_SOLVE_VALIDATION_MODEL=
